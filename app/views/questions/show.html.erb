<div class="mb-8 flex items-start justify-between gap-4">
  <h1 class="text-3xl font-bold tracking-tight"><%= @question.text %></h1>
  <%= link_to "Ask a new question", new_question_path,
        class: "shrink-0 rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white
                hover:bg-blue-700 active:bg-blue-800 transition-colors" %>
</div>

<div class="rounded-2xl border border-blue-100 bg-blue-50 px-6 py-5">
  <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-blue-400">Answer</p>
  <p class="text-gray-800 leading-relaxed"><%= @question.answer %></p>
</div>

<%= render "questions/sources", sources: @question.sources.map(&:symbolize_keys) %>
