<h1 class="text-3xl font-bold tracking-tight mb-8">Ask a Rules Question</h1>

<% if @error %>
  <p class="mb-4 text-sm text-red-600"><%= @error %></p>
<% end %>

<%= form_with url: questions_path, method: :post, data: { turbo_frame: "results" } do |f| %>
  <%= f.text_area :text,
        placeholder: "e.g. Can a creature with flying be blocked?",
        value: @question_text,
        rows: 4,
        class: "w-full rounded-xl border-2 border-gray-200 px-4 py-3 text-base text-gray-900
                placeholder:text-gray-400 focus:outline-none focus:border-blue-500
                resize-none shadow-sm" %>
  <%= f.submit "Ask",
        class: "mt-3 w-full rounded-xl bg-blue-600 py-3 text-base font-semibold text-white
                hover:bg-blue-700 active:bg-blue-800 cursor-pointer transition-colors" %>
<% end %>

<%= turbo_frame_tag "results" do %>
  <% if @question %>
    <%= turbo_stream_from "question_#{@question.id}" %>

    <div class="mt-8 rounded-2xl border border-blue-100 bg-blue-50 px-6 py-5">
      <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-blue-400">Answer</p>
      <p id="answer_text" class="text-gray-800 leading-relaxed"></p>
    </div>

    <div id="sources"></div>
  <% end %>
<% end %>
